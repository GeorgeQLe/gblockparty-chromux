{
  "name": "chromux",
  "version": "0.14.4",
  "description": "OSS desktop front-end for local and GBlockParty-managed agent/browser workspaces.",
  "main": "main.js",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GeorgeQLe/gblockparty-chromux.git",
    "directory": "prototype"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "test:detect-filter-renderer": "node scripts/test-detect-filter-renderer.js",
    "test:attention-signals-renderer": "npm run test:turn-signals-renderer",
    "test:osc-parser": "node scripts/test-osc-parser.js",
    "test:turn-signals-renderer": "node scripts/test-turn-signals-renderer.js",
    "test:tab-titles-renderer": "node scripts/test-tab-titles-renderer.js",
    "test:resume-retry-renderer": "node scripts/test-resume-retry-renderer.js",
    "test:capture-records-renderer": "node scripts/test-capture-records-renderer.js",
    "test:preview-queue-renderer": "node scripts/test-preview-queue-renderer.js",
    "test:shortcuts-renderer": "node scripts/test-shortcuts-renderer.js",
    "test:hotkey-debug-renderer": "node scripts/test-hotkey-debug-renderer.js",
    "test:browser-collapse-renderer": "node scripts/test-browser-collapse-renderer.js",
    "test:webview-shortcuts-smoke": "node scripts/test-webview-shortcuts-smoke.js",
    "test:hotkey-debug-smoke": "node scripts/test-hotkey-debug-smoke.js",
    "test:agent-command-quoting": "node scripts/test-agent-command-quoting.js",
    "test:github-update-check": "node scripts/test-github-update-check.js",
    "test:update-queue-renderer": "node scripts/test-update-queue-renderer.js",
    "package": "electron-packager . Chromux --platform=darwin --arch=arm64 --icon=build/icon --app-bundle-id=dev.georgele.chromux --overwrite --out=dist --ignore='^/dist' --ignore='^/build/icon.iconset' --asar.unpack='**/node_modules/node-pty/**'",
    "install-app": "npm run package && node scripts/record-install-source.js && rm -rf /Applications/Chromux.app && cp -R dist/Chromux-darwin-arm64/Chromux.app /Applications/Chromux.app",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@electron/rebuild": "^4.1.0",
    "electron": "^43.0.0"
  }
}
